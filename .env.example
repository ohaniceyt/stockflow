# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
# Use the Supabase anon/public JWT key here (found in Supabase Dashboard > Project Settings > API).
# The legacy VITE_SUPABASE_PUBLISHABLE_KEY is accepted as a fallback during transition.
VITE_SUPABASE_ANON_KEY=eyJhbG...

# Optional: local Supabase
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=your-local-anon-key
